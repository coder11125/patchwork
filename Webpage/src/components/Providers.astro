---
const providers = [
  { name: "Ollama", defaultModel: "llama3.2", note: "Local, no API key needed", color: "text-[var(--text)]" },
  { name: "Anthropic", defaultModel: "claude-sonnet-4-20250514", note: "Requires API key", color: "text-primary-400" },
  { name: "Mistral", defaultModel: "mistral-large-latest", note: "Requires API key", color: "text-amber-400" },
  { name: "Groq", defaultModel: "llama-3.3-70b-versatile", note: "Requires API key", color: "text-green-400" },
];
---

<section id="providers" class="border-t border-[var(--border)] px-6 py-24 sm:py-32">
  <div class="mx-auto max-w-5xl">
    <h2 class="text-center text-3xl font-bold text-[var(--text-heading)] sm:text-4xl">LLM Providers</h2>
    <p class="mx-auto mt-4 max-w-xl text-center text-[var(--text-secondary)]">
      Bring your own key — supports cloud LLMs and fully offline local models.
    </p>

    <div class="mt-12 grid gap-6 sm:grid-cols-2">
      {providers.map((p) => (
        <div class="rounded-xl border border-[var(--border)] bg-[var(--bg-card)] p-6 shadow-card">
          <div class="flex items-center justify-between">
            <h3 class={`text-lg font-bold ${p.color}`}>{p.name}</h3>
            <span class="rounded-full bg-[var(--bg-secondary)] px-3 py-1 text-xs text-[var(--text-muted)]">{p.defaultModel}</span>
          </div>
          <p class="mt-2 text-sm text-[var(--text-secondary)]">
            {p.note}
          </p>
          <div class="mt-3 font-mono text-xs text-[var(--provider-label)]">
            PATCHWORK_LLM_PROVIDER={p.name.toLowerCase()}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
