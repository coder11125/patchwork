---
const ecosystems = [
  { name: "Go Modules", file: "go.mod", textVar: "var(--eco-cyan-text)", borderVar: "var(--eco-cyan-border)" },
  { name: "npm", file: "package.json", textVar: "var(--eco-red-text)", borderVar: "var(--eco-red-border)" },
  { name: "pip", file: "requirements.txt", textVar: "var(--eco-yellow-text)", borderVar: "var(--eco-yellow-border)" },
  { name: "Cargo", file: "Cargo.toml", textVar: "var(--eco-orange-text)", borderVar: "var(--eco-orange-border)" },
  { name: "Ruby", file: "Gemfile", textVar: "var(--eco-red-text)", borderVar: "var(--eco-red-border)" },
  { name: "Maven", file: "pom.xml", textVar: "var(--eco-blue-text)", borderVar: "var(--eco-blue-border)" },
];
---

<section id="ecosystems" class="border-t border-[var(--border)] px-6 py-24 sm:py-32">
  <div class="mx-auto max-w-5xl text-center">
    <h2 class="text-3xl font-bold text-[var(--text-heading)] sm:text-4xl">Supported Ecosystems</h2>
    <p class="mx-auto mt-4 max-w-xl text-[var(--text-secondary)]">
      Detect, analyze, and upgrade packages across all major package managers.
    </p>

    <div class="mt-12 grid gap-4 sm:grid-cols-3">
      {ecosystems.map((e) => (
        <div class="rounded-lg border bg-[var(--bg-card)] px-5 py-6" style={`border-color:${e.borderVar};color:${e.textVar}`}>
          <div class="text-lg font-bold">{e.name}</div>
          <div class="mt-1 font-mono text-sm opacity-80">{e.file}</div>
        </div>
      ))}
    </div>
  </div>
</section>
